{
  "name": "dicta-fun-electron",
  "version": "1.0.5",
  "description": "Dicta Fun desktop dictation overlay",
  "private": true,
  "type": "commonjs",
  "main": "out/main/main.js",
  "scripts": {
    "postinstall": "node scripts/patch-electron-bundle.js && husky install",
    "prepare": "husky install",
    "dev": "node scripts/run-electron-vite.cjs dev",
    "build": "tsc --noEmit && electron-vite build",
    "preview": "node scripts/run-electron-vite.cjs preview",
    "test": "node -e \"require('node:fs').rmSync('.test-build',{recursive:true,force:true})\" && tsc -p tsconfig.test.json && node --test .test-build/tests/*.test.js",
    "predist": "node scripts/download-whisper-model.js",
    "dist": "npm run build && electron-builder --publish never",
    "dist:mac": "npm run prebuild:mac && npm run build && electron-builder --mac --publish never",
    "dist:win": "npm run prebuild:win && npm run build && electron-builder --win --publish never",
    "prebuild:mac": "node scripts/download-whisper-model.js",
    "prebuild:win": "node scripts/download-whisper-model.js && node scripts/download-nircmd.js",
    "download:whisper-model": "node scripts/download-whisper-model.js",
    "download:nircmd": "node scripts/download-nircmd.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@electron/windows-sign": "^1.2.2",
    "@types/node": "^22.16.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.0",
    "husky": "^9.1.7",
    "semantic-release": "^24.2.0",
    "typescript": "^5.8.3",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "com.dictafun.desktop",
    "productName": "Dicta Fun",
    "files": [
      "out/**/*",
      "resources/**/*",
      "!resources/bin/**",
      "!resources/models/**"
    ],
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin"
      },
      {
        "from": "resources/models",
        "to": "models"
      }
    ],
    "mac": {
      "icon": "resources/icon.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Dicta Fun uses the microphone to transcribe your speech."
      }
    },
    "win": {
      "icon": "resources/icon.ico",
      "target": "nsis"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  }
}
