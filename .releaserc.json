{
  "branches": [
    {
      "name": "main",
      "channel": false
    },
    {
      "name": "feature/*",
      "channel": "pre",
      "prerelease": "rc"
    },
    {
      "name": "feat/*",
      "channel": "pre",
      "prerelease": "rc"
    },
    {
      "name": "fix/*",
      "channel": "pre",
      "prerelease": "rc"
    },
    {
      "name": "chore/*",
      "channel": "pre",
      "prerelease": "rc"
    },
    {
      "name": "hotfix/*",
      "channel": "pre",
      "prerelease": "rc"
    }
  ],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/npm",
      {
        "npmPublish": false
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "package.json",
          "package-lock.json",
          "CHANGELOG.md"
        ],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    "@semantic-release/github"
  ]
}
